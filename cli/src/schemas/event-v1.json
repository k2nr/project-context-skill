{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:project-context:event:1",
  "title": "Project Context Event",
  "oneOf": [
    { "$ref": "#/$defs/decision" },
    { "$ref": "#/$defs/attempt" }
  ],
  "$defs": {
    "common": {
      "type": "object",
      "required": ["schema_version", "type", "id", "date", "subject"],
      "properties": {
        "schema_version": { "const": 1 },
        "type": { "type": "string" },
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "subject": { "type": "string", "minLength": 1 },
        "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      }
    },
    "decision": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema_version", "type", "id", "date", "subject", "decision", "reason"],
          "properties": {
            "schema_version": { "const": 1 },
            "type": { "const": "decision" },
            "id": { "type": "string", "pattern": "^D-[0-9]+$" },
            "date": { "type": "string", "format": "date", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
            "subject": { "type": "string", "minLength": 1 },
            "decision": { "type": "string", "minLength": 1 },
            "reason": { "type": "string", "minLength": 1 },
            "rejected": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "supersedes": { "type": "array", "items": { "type": "string", "pattern": "^D-[0-9]+$" }, "uniqueItems": true },
            "conditions": { "type": "string", "minLength": 1 },
            "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
          }
        }
      ]
    },
    "attempt": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema_version", "type", "id", "date", "subject", "approach", "result", "finding"],
          "properties": {
            "schema_version": { "const": 1 },
            "type": { "const": "attempt" },
            "id": { "type": "string", "pattern": "^A-[0-9]+$" },
            "date": { "type": "string", "format": "date", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
            "subject": { "type": "string", "minLength": 1 },
            "approach": { "type": "string", "minLength": 1 },
            "result": { "enum": ["succeeded", "failed", "partial", "inconclusive"] },
            "finding": { "type": "string", "minLength": 1 },
            "conditions": { "type": "string", "minLength": 1 },
            "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
          }
        }
      ]
    }
  }
}
