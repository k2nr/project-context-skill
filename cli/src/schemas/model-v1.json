{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:project-context:model:1",
  "title": "Project Context Model",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project", "principles", "architecture", "behaviors", "constraints", "operations", "extensions"],
  "properties": {
    "schema_version": { "const": 1 },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "principles": { "$ref": "#/$defs/entries" },
    "architecture": { "$ref": "#/$defs/entries" },
    "behaviors": { "$ref": "#/$defs/entries" },
    "constraints": { "$ref": "#/$defs/entries" },
    "operations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["build", "test", "lint", "format"],
      "properties": {
        "build": { "$ref": "#/$defs/commands" },
        "test": { "$ref": "#/$defs/commands" },
        "lint": { "$ref": "#/$defs/commands" },
        "format": { "$ref": "#/$defs/commands" }
      }
    },
    "extensions": { "type": "object" }
  },
  "$defs": {
    "entries": { "type": "array", "items": { "$ref": "#/$defs/entry" } },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "statement": { "type": "string", "minLength": 1 },
        "related_events": { "type": "array", "items": { "type": "string", "pattern": "^[DA]-[0-9]+$" }, "uniqueItems": true }
      }
    },
    "commands": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}
