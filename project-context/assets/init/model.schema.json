{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:project-context:model:3",
  "title": "Project Context Model",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project", "principles", "architecture", "behaviors", "constraints", "operations", "extensions"],
  "properties": {
    "schema_version": { "const": 3 },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "principles": { "$ref": "#/$defs/entries" },
    "architecture": { "$ref": "#/$defs/entries" },
    "behaviors": { "$ref": "#/$defs/entries" },
    "constraints": { "$ref": "#/$defs/entries" },
    "operations": {
      "type": "object",
      "propertyNames": { "pattern": "^[a-z][a-z0-9._-]*$" },
      "additionalProperties": { "type": "array", "items": { "$ref": "#/$defs/operation_step" } }
    },
    "extensions": { "type": "object" }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref"],
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "role": { "enum": ["choice", "rationale", "outcome", "implementation", "context"] },
        "observed_at": { "type": "string", "format": "date-time" }
      }
    },
    "event_relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event", "kind"],
      "properties": {
        "event": { "type": "string", "pattern": "^[DA]-[0-9]+$" },
        "kind": { "enum": ["origin", "rationale", "validation", "implementation", "constraint", "related"] }
      }
    },
    "entries": { "type": "array", "items": { "$ref": "#/$defs/entry" } },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "statement": { "type": "string", "minLength": 1 },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" }, "uniqueItems": true },
        "event_relations": { "type": "array", "items": { "$ref": "#/$defs/event_relation" }, "uniqueItems": true }
      }
    },
    "operation_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "cwd": { "type": "string", "minLength": 1 },
        "env": {
          "type": "object",
          "propertyNames": { "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
