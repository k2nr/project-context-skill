#!/bin/sh
set -eu

if [ "$#" -ne 2 ]; then
  printf 'usage: %s VERSION OUTPUT_DIRECTORY\n' "$0" >&2
  exit 2
fi

version=$1
output_directory=$2
case "$version" in
  ''|*[!0-9.]*) printf 'package-installer: invalid version: %s\n' "$version" >&2; exit 2 ;;
esac

script_directory=$(
  CDPATH=
  cd -- "$(dirname -- "$0")"
  pwd
)
source_installer="${script_directory}/install-project-context"
embedded_version=$(sed -n 's/^PROJECT_CONTEXT_VERSION="\([^"]*\)"/\1/p' "$source_installer")
[ "$embedded_version" = "$version" ] \
  || { printf 'package-installer: embedded version %s does not match %s\n' "$embedded_version" "$version" >&2; exit 2; }

mkdir -p "$output_directory"
asset_name="install-project-context-v${version}"
asset="${output_directory}/${asset_name}"
cp "$source_installer" "$asset"
chmod 755 "$asset"
touch -t 197001010000 "$asset"

if command -v sha256sum >/dev/null 2>&1; then
  checksum=$(sha256sum "$asset")
else
  checksum=$(shasum -a 256 "$asset")
fi
printf '%s  %s\n' "${checksum%% *}" "$asset_name" > "${asset}.sha256"
printf '%s\n' "$asset"
