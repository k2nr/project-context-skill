#!/bin/sh
set -eu

repository_root=$(
  CDPATH=
  cd -- "$(dirname -- "$0")/.."
  pwd
)
cd "$repository_root"

check_build() {
  cargo build --locked --manifest-path cli/Cargo.toml
}

check_format() {
  cargo fmt --manifest-path cli/Cargo.toml -- --check
}

check_lint() {
  cargo clippy --locked --manifest-path cli/Cargo.toml --all-targets -- -D warnings
  shellcheck \
    project-context/bin/project-context \
    project-context/bin/update-project-context \
    bin/check \
    bin/install-project-context \
    bin/package-installer \
    bin/package-skill \
    bin/validate-skill \
    tests/*.sh
  for script_file in \
    project-context/bin/project-context \
    project-context/bin/update-project-context \
    bin/check \
    bin/install-project-context \
    bin/package-installer \
    bin/package-skill \
    bin/validate-skill \
    tests/*.sh; do
    sh -n "$script_file"
  done
  bin/validate-skill project-context
  bin/validate-skill reconstruct-project-context
  python3 bin/validate-skill-yaml project-context
  python3 bin/validate-skill-yaml reconstruct-project-context
}

check_test() {
  cargo test --locked --manifest-path cli/Cargo.toml
  tests/test-bootstrap.sh project-context/bin/project-context
  tests/test-skill-validator.sh
  tests/test-package.sh
  tests/test-installer-package.sh
  tests/test-installer.sh
  tests/test-update.sh
  tests/test-reconstruction.sh
  .agents/skills/project-context/bin/project-context validate --strict
}

usage() {
  printf 'usage: bin/check {build|format|lint|test|verify}\n' >&2
  exit 2
}

[ "$#" -eq 1 ] || usage
case "$1" in
  build) check_build ;;
  format) check_format ;;
  lint) check_lint ;;
  test) check_test ;;
  verify)
    check_build
    check_format
    check_lint
    check_test
    ;;
  *) usage ;;
esac
